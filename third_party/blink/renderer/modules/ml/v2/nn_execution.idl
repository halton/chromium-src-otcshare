interface NNExecution {
  [RaisesException] void setInput(DOMString name, [AllowShared] ArrayBufferView data);
  [RaisesException] void setOutput(DOMString name, [AllowShared] ArrayBufferView data);
  [CallWith=ScriptState] Promise<void> startCompute();
};