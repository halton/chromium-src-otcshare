import("//third_party/blink/renderer/modules/modules.gni")

blink_modules_sources("ml") {
  sources = [
    "ml.cc",
    "ml.h",
    "ml_context.cc",
    "ml_context.h",
    "ml_model.cc",
    "ml_model.h",
    "ml_model_loader.cc",
    "ml_model_loader.h",
  ]

  deps = [ "//components/ml/mojom:mojom_blink" ]

  # WebNN sources
  sources += [
    "webnn/ml_graph.cc",
    "webnn/ml_graph.h",
    "webnn/ml_graph_builder.cc",
    "webnn/ml_graph_builder.h",
    "webnn/ml_object.cc",
    "webnn/ml_object.h",
    "webnn/ml_operand.cc",
    "webnn/ml_operand.h",
    "webnn/ml_operator.cc",
    "webnn/ml_operator.h",
    "webnn/mojo_client.cc",
    "webnn/mojo_client.h",
    "webnn/mojo_context.cc",
    "webnn/mojo_context.h",
    "webnn/mojo_graph.cc",
    "webnn/mojo_graph.h",
  ]
}
