module ml.mojom;

// https://github.com/webmachinelearning/model-loader/blob/main/explainer.md

struct Float32List {
  array<float> value;
};

struct Float64List {
  array<double> value;
};

struct Int8List {
  array<int8> value;
};

struct Uint8List {
  array<uint8> value;
};

struct Int16List {
  array<int16> value;
};

struct Uint16List {
  array<uint16> value;
};

struct Int32List {
  array<int32> value;
};

struct Uint32List {
  array<uint32> value;
};

struct Int64List {
  array<int64> value;
};

struct Uint64List {
  array<uint64> value;
};

union ValueList {
  Float32List float32_list;
  Float64List float64_list;
  Int8List int8_list;
  Uint8List uint8_list;
  Int16List int16_list;
  Uint16List uint16_list;
  Int32List int32_list;
  Uint32List uint32_list;
  Int64List int64_list;
  Uint64List uint64_list;
};

// Represents a tensor, corresponding to MLTensor dictionary in the idl
// definition.
struct Tensor {
  ValueList data;
  Uint32List dimensions;
};

enum ComputeResult {
  kOk,
  // Computing the model can not be supported.
  kNotSupported,
  kUnknownError,
};

// Represents the model loaded. Corresponding to the `MLModelLoaded` interface
// in the IDL definition.
interface ModelLoaded {
  Compute(map<string, Tensor> input)
      => (ComputeResult result, map<string, Tensor>? output);
};

enum LoadModelResult {
  kOk,
  // There is no supporting backend for WebML model loader API.
  kNotSupported,
  // Wrong model specification.
  kWrongModelSpec,
  // Can not load the model (e.g. the model format is wrong, etc.).
  kLoadModelError,
  kUnknownError,
};

// Specify the input/output nodes of the model.
// There are two ways of specifying it.
//   - Use a sequence of strings. The strings can be the names or the indices
//     of the nodes.
//   - Use a map from node names to indices. The node names can be used in
//     the `ModelLoaded.compute` function.
// Corresponds to the `MLLoadModelIOSpec` type in the IDL definition.
union LoadModelIOSpec {
  array<string> array_of_strings;
  map<string, uint64> names_to_indices;
};

// The options used in loading models.
// Corresponds to the `MLLoadModelOptions` dictionary in the IDL definition.
struct LoadModelOptions {
  LoadModelIOSpec inputs;
  LoadModelIOSpec outputs;
};

// Represents the Machine Learning service, corresponding to the `ML` interface
// in the IDL definition.
// TODO(honglinyu): add an API to query the available features.
interface MLService {
  Load(array<uint8> model_content, LoadModelOptions options)
      => (LoadModelResult result, pending_remote<ModelLoaded>? model_loaded);
};
