module ml.webnn.mojom;

import "mojo/public/mojom/base/shared_memory.mojom";

// Represents the `MLOperandType` that is the type of operand, the type can not
// be set for describing output which isn't used in native implementation.
[Stable, Extensible]
enum OperandType {
  [Default] kFloat32,
  kFloat16,
  kInt32,
  kUint32,
  kInt8,
  kUint8,
};

// Represents the `MLOperandDescriptor` which describes not only input and
// constant operand, but also intermediate node.
[Stable]
struct OperandDescriptor {
  // The type of the operand.
  OperandType data_type@0;
  // The dimensions of the operand.
  array<int32> dimensions@1;
  // The object id of the operand.
  uint32 object_id@2;
};

// Represents the activation function types, the `kUnknown` is used to throw
// exception for unsupported type in blink.
[Stable, Extensible]
enum FusionType { [Default] kUnknown = 0, kClamp, kRelu };

// Represents the `MLOperator` in the WebIDL definition that is used to fuse
// into another operation such as conv2d.
[Stable]
struct FusionOperator {
  // The object id of the fused operator that is used to get its parameters.
  uint32 object_id@0;
  // The type of the fusion operator.
  FusionType fusion_type@1;
};

// Represents the `MLInputOperandLayout` that specifies the layout format of
// the input tensor.
// N is the batch, C is input channels, H is height and W is the width of the
// tensor.
[Stable, Extensible]
enum InputOperandLayout { [Default] kNchw, kNhwc };

// Represents the `MLConv2dFilterOperandLayout` that specifies the layout format
// of filter tensor.
// O is the output channel, i is input channel, H is height and W is the width
//  of the tensor.
[Stable, Extensible]
enum Conv2dFilterOperandLayout { [Default] kOihw, kHwio, kOhwi, kIhwo };

// Represents the `MLAutoPad`. `Explicit` means that the values in the
// options.padding array should be used for input padding, with `SameUpper`
// and `SameLower` options, the padding values are automatically computed.
[Stable, Extensible]
enum AutoPad { [Default] kExplicit, kSameUpper, kSameLower };

// Represents the `MLConv2dOptions`.
[Stable]
struct Conv2dOptions {
  // The additional rows and columns added to the beginning and ending of each
  // spatial dimension of input.
  array<int32> padding@0;
  // The stride of the sliding window for each spatial dimension of input.
  array<int32> strides@1;
  // The dilation factor for each spatial dimension of input.
  array<int32> dilations@2;
  // The automatic input padding options.
  AutoPad auto_pad@3 = AutoPad.kExplicit;
  // The number of groups that input channels and output channels are divided
  // into.
  int32 groups@4 = 1;
  // The layout format of the input.
  InputOperandLayout inputLayout@5 = InputOperandLayout.kNchw;
  // The layout format of the filter.
  Conv2dFilterOperandLayout filterLayout@6 = Conv2dFilterOperandLayout.kOihw;
  // The object id of bias operand that is additional 1-D tensor with the shape
  // of [output_channels] whose values are to be added to the convolution
  // result.
  uint32 bias_id@7;
  //The optional activation function that immediately follows the convolution
  // operation.
  FusionOperator? activation@8;
};

// Represents the `MLGemmOptions`.
[Stable]
struct GemmOptions {
  // The object id of third input tensor.
  uint32 c_id@0;
  // The scalar multiplier for the first input.
  float alpha@1 = 1.0;
  // The scalar multiplier for the third input.
  float beta@2 = 1.0;
  // If the first input should be transposed prior to calculating the output.
  bool a_transpose@3 = false;
  // If the second  input should be transposed.
  bool b_transpose@4 = false;
};

// Represents the `MLPool2dType`, the `kUnknown` is used to throw exception for
// unsupported type in blink.
[Stable, Extensible]
enum Pool2dType {
  [Default] kUnknown = 0,
  kAveragePool2d,
  kMaxPool2d,
  kL2Pool2d
};

[Stable, Extensible]
enum RoundingType { [Default] kFloor, kCeil };

// Represents the `MLPool2dOptions`.
[Stable]
struct Pool2dOptions {
  // The dimensions of the sliding window.
  array<int32> window_dimensions@0;
  // The additional rows and columns added to the beginning and ending of each
  // spatial dimension of input.
  array<int32> padding@1;
  // The stride of the sliding window for each spatial dimension of input.
  array<int32> strides@2;
  // The dilation factor for each spatial dimension of input.
  array<int32> dilations@3;
  // The automatic input padding options.
  AutoPad auto_pad@4 = AutoPad.kExplicit;
  // The layout format of the input.
  InputOperandLayout layout@5 = InputOperandLayout.kNchw;
  // The rounding function used to compute the output shape.
  RoundingType rounding_type@6 = RoundingType.kFloor;
  // The sizes of the two spacial dimensions of the output tensor.
  array<int32> output_sizes@7;
};

// Represents the `MLClampOptions`.
[Stable]
struct ClampOptions {
  // Specifies the minimum value of the range.
  float minValue@0;
  // Specifies the maximum value of the range.
  float maxValue@1;
};

// Represents element-wise binary operation, the `kUnknown` is used to throw
// exception for unsupported type in blink.
[Stable, Extensible]
enum BinaryOperandType {
  [Default] kUnknown = 0,
  kAdd,
  kSub,
  kMul,
  kDiv,
  kMax,
  kMin,
  kMatMul,
  kPower,
};

// Represents unary operation, the `kUnknown` is used to throw exception for
// unsupported type in blink.
[Stable, Extensible]
enum UnaryOperandType {
  [Default] kUnknown = 0,
  kRelu,
  kSoftmax,
  kSigmoid,
};

// Describe the information of inputs / outputs data in shared buffer.
[Stable]
struct MemoryInfo {
  // The offset of buffer.
  uint64 byte_offset@0;
  // The length of buffer.
  uint64 byte_length@1;
};

// Represents the `MLNamedInputs`.
[Stable]
struct NamedInputs {
  map<string, MemoryInfo> inputs@0;
  mojo_base.mojom.ReadOnlySharedMemoryRegion shared_memory@1;
};

// Represents the `MLNamedOutputs`.
[Stable]
struct NamedOutputs {
  map<string, MemoryInfo> outputs@0;
  mojo_base.mojom.ReadOnlySharedMemoryRegion shared_memory@1;
};

// Used by `BuildGraph()` of interface Graph.
[Stable, Extensible]
enum BuildResult {
  [Default] kOk,
  kUnknownError,
};

// Used by `Compute()` of interface Graph.
[Stable, Extensible]
enum ComputeResult {
  [Default] kOk,
  kUnknownError,
};

// Corresponds to the `MLGraph` object in the WebIDL definition. The user can
// use its `Compute` interface to do inferences.
[Stable]
interface Graph {
  // Corresponds to `MLOperand input(DOMString name, MLOperandDescriptor desc)`
  // function in `MLGraphBuilder`.
  // It's to add a input operand in the graph with name and the descriptor,
  // the `OperandDescriptor` describe its type, dimensions and object id of
  // input operand.
  AddInput@0(string name, OperandDescriptor desc);

  // Corresponds to `MLOperand constant(MLOperandDescriptor desc, MLBufferView
  // bufferView)` array buffer implementation in `MLGraphBuilder`.
  // It's to add a constant operand in the graph with the descriptor and data
  // that is cpu buffer.
  AddConstant@1(OperandDescriptor desc, array<uint8> array_buffer);

  // Add element-wise binary addition, subtraction, multiplication, division
  // defined in `BinaryOperandType`. `a_id` is the object id of first input
  // operand, `b_id` is the object id of second input operand, `output_desc` is
  // the descriptor of output operand including object id and dimensions.
  AddElementWiseBinary@3(uint32 a_id, uint32 b_id, BinaryOperandType type,
      OperandDescriptor output_desc);

  // Corresponds to `MLOperand clamp(MLOperand x, MLClampOptions options)` 
  // function in `MLGraphBuilder`.
  // `input_id` is the object id of input operand `x`.
  AddClamp@4(uint32 input_id, ClampOptions options,
      OperandDescriptor output_desc);

  // Corresponds to `MLOperand conv2d(MLOperand input, MLOperand filter, 
  // MLConv2dOptions options)` function in `MLGraphBuilder`.
  // `input_id` is the object id of input operand, `filter_id` is the object id
  // of filter operand.
  AddConv2d@5(uint32 input_id, uint32 filter_id, Conv2dOptions options,
      OperandDescriptor output_desc);

  // Corresponds to `MLOperand reshape(MLOperand input, sequence<long> shape)` 
  // function in `MLGraphBuilder`.
  // `input_id` is the object id of input operand, the `shape` is set with the
  // dimensions of `output_desc`. 
  AddReshape@6(uint32 input_id, OperandDescriptor output_desc);

  // Corresponds to `MLOperand gemm(MLOperand a, MLOperand b, MLGemmOptions
  // options)` function in `MLGraphBuilder`.
  // `a_id` is the object id of `a` operand, `b_id` is the object id of `b` 
  // operand.
  AddGemm@7(uint32 a_id, uint32 b_id, GemmOptions options,
      OperandDescriptor output_desc);

  // Add a mean, L2 norm, or max reduction operation defined in `Pool2dType`
  // across all the elements within the moving window over the input tensor.
  AddPool2d@8(uint32 input_id, Pool2dOptions options, Pool2dType type,
      OperandDescriptor output_desc);

  // Add unary operation relu, softmax, sigmoid defined in `UnaryOperandType`.
  // `input_id` is the object id of input operand.
  AddUnary@9(uint32 input_id, UnaryOperandType type,
      OperandDescriptor output_desc);

  // Corresponds to `MLOperator clamp(MLClampOptions options)` function in
  // `MLGraphBuild`.
  // `operator_id` is the object id of the clamp fusion operator.
  AddFusionClamp@10(ClampOptions options, uint32 operator_id);

  // Compile the `MLGraphBuild` state up to the specified output operands into
  // a compiled graph according to the type of `MLContext` that creates it.
  // `result` is the status of building graph.
  Build@11(map<string, uint32> named_operands) => (BuildResult result);

  // Carries out the computational workload of a compiled graph.
  // `named_inputs` is the resources of inputs with shared memory,
  // `named_outputs` is the result of inference which return to renderer process
  // with shared memory.
  Compute@12(NamedInputs named_inputs)
      => (ComputeResult result, NamedOutputs? named_outputs);
};
